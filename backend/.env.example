# ---------------------------------------------------------------------------
# Soil Care System — backend configuration
# Copy to `.env` and adjust. All values have sane local defaults.
# ---------------------------------------------------------------------------

# Database. Default is zero-setup SQLite (file in backend/).
# For PostgreSQL (as in the original TZ) use e.g.:
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/soilcare
DATABASE_URL=sqlite+aiosqlite:///./soilcare.db

# Directory holding the model artifacts (best_model.pth + *.pkl).
# Relative to the backend/ working directory.
WEIGHTS_DIR=app/ml/weights

# Torch device for the EfficientNet image classifier: cpu | cuda | mps
DEVICE=cpu

# CORS — comma separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
